# ==============================================================================
# TASKNEST ENVIRONMENT TEMPLATE
# ==============================================================================

# DATABASE: MySQL (Recommended: PlanetScale, Railway, or Aiven)
# If using PlanetScale, ensure you append ?sslaccept=strict to the URL.
DATABASE_URL="mysql://user:password@host:3306/tasknest"

# PRISMA: Shadow Database (Required for some cloud providers during migrations)
# SHADOW_DATABASE_URL="mysql://user:password@host:3306/tasknest_shadow"

# AUTHENTICATION (NextAuth.js)
# Generate a secret via: openssl rand -base64 32
NEXTAUTH_SECRET="your_secret_here"
NEXTAUTH_URL="http://localhost:3000"

# APP SETTINGS
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NODE_ENV="development"

# API KEYS (Optional: If you implement email/notifications later)
# RESEND_API_KEY="re_..."
# STRIPE_SECRET_KEY="sk_test_..."
