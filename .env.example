# .env.example - Template for Tasknest environment variables
# Copy this file to .env and fill in your actual credentials.
# DO NOT commit your actual .env file to version control.

# --- Database Configuration ---
# Tasknest uses MySQL. We recommend PlanetScale or Railway for easy deployment.

# Local / Standard MySQL
DATABASE_URL="mysql://your_user:your_password@localhost:3306/tasknest"

# PlanetScale Example:
# DATABASE_URL="mysql://username:pscale_pw_xxxxxx@aws.connect.psdb.cloud/tasknest?sslaccept=strict"

# Railway Example:
# DATABASE_URL="mysql://root:your_password@containers-us-west-1.railway.app:5432/railway"
