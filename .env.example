# .env.example

# Required environment variables for Tasknest
# Use PlanetScale or Railway for serverless MySQL databases

# Database connection string
DATABASE_URL=mysql://user:password@host:port/database

# Example for PlanetScale:
# DATABASE_URL=mysql://root:pscale_pw_xxxxx@xxxxx.us-east-1.psdb.cloud/tasknest?sslaccept=strict

# Example for Railway:
# DATABASE_URL=mysql://root:password@host:port/tasknest